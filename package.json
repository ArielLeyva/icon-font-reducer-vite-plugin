{
  "name": "vite-plugin-icon-font-reducer",
  "version": "0.1.0",
  "description": "Reduce icon font files automatically during Vite builds.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "fonts",
    "icons",
    "subset",
    "fontawesome"
  ],
  "peerDependencies": {
    "vite": "^5 || ^6"
  },
  "license": "MIT",
  "dependencies": {
    "icon-font-reducer": "^2.1.7",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
